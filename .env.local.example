# Local-development overrides for Vite. Copy to `.env.local` (which is
# gitignored by Vite default) and edit the value.
#
# Setting this points the local dev frontend at the staging Cloudflare Worker
# instead of the production API. Production builds (without .env.local) read
# the API base from /data/config.json as before.
#
# Find your staging Worker URL in the output of `wrangler deploy --env staging`.
# It looks like: https://mashmaut-api-staging.<your-subdomain>.workers.dev

VITE_API_BASE=https://mashmaut-api-staging.alonmashmaut-ea1.workers.dev
